{
  "debug": true,
  "branches": [
    {
      "name": "+([0-9])?(.{+([0-9]),x}).x",
      "prerelease": "snapshot"
    },
    {
      "name": "master",
      "prerelease": "snapshot"
    },
    {
      "name": "beta",
      "prerelease": "beta"
    }
  ],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    "@semantic-release/github"
  ]
}
